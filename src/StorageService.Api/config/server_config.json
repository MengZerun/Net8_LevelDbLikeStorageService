    "ip": "127.0.0.1",
    "mode": "sub",
    "port": "9201",
    "protocol": "tcp",
    "topic": [],
    "type": "recv",
    "enabled": true
  },
  {
    "description": "PUB 发布数据库处理结果",
    "id": "db_result_pub",
    "filter": [],
    "ip": "*",
    "mode": "pub",
    "port": "9202",
    "protocol": "tcp",
    "topic": ["fromDb_to_station2", "dbrep"],
    "type": "send",
    "enabled": true
  }
