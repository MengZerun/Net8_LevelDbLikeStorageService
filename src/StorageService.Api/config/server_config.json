[
  {
    "description": "ROUTER 接收外部请求，支持 request/reply",
    "id": "db_router",
    "filter": [],
    "ip": "*",
    "mode": "router",
    "port": "9199",
    "protocol": "tcp",
    "topic": [],
    "type": "recv",
    "enabled": true
  },
  {
    "description": "SUB 接收工站发来的数据库请求",
